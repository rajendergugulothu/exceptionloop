# Copy to .env.production and fill in real values before deploying

# Database — use Neon, Railway, or Supabase in production
DATABASE_URL=postgresql+asyncpg://user:password@host:5432/exceptionloop

# AI
ANTHROPIC_API_KEY=sk-ant-...
OPENAI_API_KEY=sk-proj-...

# CORS — comma-separated list of allowed frontend origins
ALLOWED_ORIGINS=https://exceptionloop.vercel.app,https://yourdomain.com

# Zendesk
ZENDESK_WEBHOOK_SECRET=your-webhook-secret
ZENDESK_SUBDOMAIN=yourcompany
ZENDESK_API_TOKEN=your-zendesk-api-token
ZENDESK_EMAIL=your-email@company.com

APP_ENV=production
SECRET_KEY=generate-with-openssl-rand-hex-32
