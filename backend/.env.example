# Database (must have pgvector extension installed)
DATABASE_URL=postgresql+asyncpg://postgres:password@localhost:5432/exceptionloop

# Anthropic (for classification, recommendation generation, readiness scoring)
ANTHROPIC_API_KEY=sk-ant-...

# OpenAI (for text-embedding-3-small)
OPENAI_API_KEY=sk-...

# Zendesk
ZENDESK_WEBHOOK_SECRET=your-zendesk-webhook-secret
ZENDESK_SUBDOMAIN=yourcompany
ZENDESK_API_TOKEN=your-zendesk-api-token
ZENDESK_EMAIL=your-email@company.com

# App
APP_ENV=development
SECRET_KEY=change-me-in-production
